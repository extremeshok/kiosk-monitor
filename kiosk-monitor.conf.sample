# kiosk-monitor configuration
# Copy to /etc/kiosk-monitor/kiosk-monitor.conf and adjust values as needed.

URL="http://192.168.3.222:30059/?Birdseye"
GUI_USER=""          # set to the desktop user if auto-detection fails
BROWSER="chromium"    # Chromium/Chrome only
# CHROMIUM_BIN="/usr/bin/chromium-browser"
DEBUG=false
PROFILE_ROOT=""       # override kiosk profile directory if needed
WAIT_FOR_URL=true
CHROME_LAUNCH_DELAY=3
CHROME_READY_DELAY=2
MIN_UPTIME_BEFORE_START=60   # ensure the Pi has been up at least N seconds before launching
PROFILE_TMPFS=false
PROFILE_TMPFS_PATH="/dev/shm/kiosk-monitor"
PROFILE_SYNC_BACK=false
PROFILE_TMPFS_PURGE=false
PROFILE_ARCHIVE=""
PROFILE_SYNC_INTERVAL=0
PREWARM_ENABLED=true
PREWARM_PATHS=""
PREWARM_MAX_FILES=512
PREWARM_SLICE_SIZE=262144
SESSION_READY_DELAY=0
SESSION_READY_CMD=""
SESSION_READY_TIMEOUT=0
GUI_SESSION_WAIT_TIMEOUT=120   # wait up to N seconds for the GUI user’s loginctl session before launching (0 disables)
WAIT_FOR_URL_TIMEOUT=0         # seconds to wait for initial health check before proceeding anyway (0=wait forever)
SCREEN_SAMPLE_BYTES=524288     # bytes hashed when region hashing fails (legacy fallback)
SCREEN_SAMPLE_MODE="sample"    # "sample" hashes the top-left 50% via SHA-256; set to "full" for the entire frame
SCREEN_DELAY=120               # seconds the browser must run before screen-freeze checks begin
HEALTH_INTERVAL=30             # seconds between health-check cycles
HEALTH_CONNECT_TIMEOUT=2       # curl connect timeout (seconds) for health checks
HEALTH_TOTAL_TIMEOUT=6         # max curl duration (seconds) per health check
STALL_RETRIES=3                # unchanged screen hashes before forcing a restart
HEALTH_RETRIES=6               # consecutive failed health probes before restarting browser
RESTART_WINDOW=600             # seconds considered when rate-limiting restarts
MAX_RESTARTS=10                # max restarts allowed within RESTART_WINDOW before backoff
CLEAN_RESET=600                # seconds of healthy run needed to reset restart history
DEVTOOLS_AUTO_OPEN=false       # set true to auto-open Chromium DevTools for each tab
DEVTOOLS_REMOTE_PORT=          # set a port (e.g., 9222) to enable Chromium remote debugging
LOCK_FILE="/var/lock/kiosk-monitor.lock"  # non-root runs fall back to $XDG_RUNTIME_DIR/kiosk-monitor.lock or /tmp automatically
INSTALL_DIR="/usr/local/bin"
SERVICE_PATH="/etc/systemd/system/kiosk-monitor.service"
BASE_URL="https://raw.githubusercontent.com/extremeshok/kiosk-monitor/main"
BIRDSEYE_AUTO_FILL=true       # set to false to disable the Frigate Birdseye auto-fill CSS
BIRDSEYE_MATCH_PATTERN=""     # override the Chrome extension match pattern (defaults to scheme://host/* derived from URL)
BIRDSEYE_EXTENSION_DIR=""     # optional custom directory; defaults to <PROFILE_ROOT>/birdseye-autofill with fallback to /usr/local/share/kiosk-monitor
